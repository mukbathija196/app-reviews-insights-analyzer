# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: groq | gemini | ollama
# - groq:   free-tier Groq API (default)
# - gemini: free-tier Gemini API (optional fallback)
# - ollama: fully local, zero external network calls
LLM_PROVIDER=groq

# ── Gemini (free tier) ────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Groq (free tier) ─────────────────────────────────────────────────────────
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=

# ── Ollama (local, no key needed) ─────────────────────────────────────────────
# Run: ollama serve   then   ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Embeddings ────────────────────────────────────────────────────────────────
# Local CPU model — downloaded once to ~/.cache/huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Data paths (override if needed) ───────────────────────────────────────────
# PULSE_DATA_DIR=./data
# PULSE_CONFIG_DIR=./config

# ── On-demand web portal (GitHub workflow trigger) ───────────────────────────
# Personal Access Token with Actions: write and Actions: read permissions.
# GITHUB_TOKEN=
# Your repository slug, e.g. "owner/repo-name"
# PULSE_GITHUB_REPO=
# Optional branch/ref for workflow_dispatch (default: main)
# PULSE_WORKFLOW_REF=main
# Optional workflow filename (default: pulse.yml)
# PULSE_WORKFLOW_FILE=pulse.yml
